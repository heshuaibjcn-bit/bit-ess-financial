# AI API Keys 配置
#
# 获取 API Keys:
#
# 1. 智谱AI GLM API Key:
#    - 访问: https://open.bigmodel.cn/
#    - 注册/登录账号
#    - 创建 API Key
#    - 复制 key 到下方 VITE_GLM_API_KEY
#
# 2. Anthropic Claude API Key:
#    - 访问: https://console.anthropic.com/
#    - 注册/登录账号
#    - 创建 API Key
#    - 复制 key 到下方 VITE_ANTHROPIC_API_KEY
#
# 注意：
# - 此文件包含敏感信息，请勿提交到版本控制系统
# - .gitignore 已配置忽略 .env 文件
# - 实际使用时，复制此文件为 .env 并填入真实的 API Keys

# ============================================================================
# 智谱AI GLM API Key (主要 - 智能体框架)
# ============================================================================
# 用于: NanoAgent 框架、电价更新智能体、政策分析智能体等
# 获取地址: https://open.bigmodel.cn/
VITE_GLM_API_KEY=your_glm_api_key_here

# ============================================================================
# Anthropic Claude API Key (可选 - 投资顾问、AI 聊天)
# ============================================================================
# 用于: AI 投资顾问、AI 聊天功能
# 获取地址: https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================================================
# AI 提供商选择
# ============================================================================
# 选项:
#   - glm: 使用智谱AI GLM (需要 VITE_GLM_API_KEY)
#   - anthropic: 使用 Anthropic Claude (需要 VITE_ANTHROPIC_API_KEY)
#   - openai: 使用 OpenAI GPT (需要 VITE_OPENAI_API_KEY)
#   - mock: 使用模拟数据（无需 API Key，用于开发测试）
VITE_AI_PROVIDER=glm

# ============================================================================
# OpenAI API Key (可选)
# ============================================================================
# 用于: 备用 AI 提供商
# 获取地址: https://platform.openai.com/
# VITE_OPENAI_API_KEY=your_openai_api_key_here
