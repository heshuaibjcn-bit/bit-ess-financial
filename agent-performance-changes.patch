+              <li>• All ${AGENT_CONFIGS.length} agents executed concurrently</li>
+              <li>• ${efficiency > 80 ? 'Excellent' : efficiency > 50 ? 'Good' : 'Fair'} parallelization efficiency (${efficiency.toFixed(1)}%)</li>
+            </ul>
+          </div>
+        </div>
+      `;
+
+      // Add comparison at the top
+      document.getElementById('results').innerHTML = comparisonHtml + document.getElementById('results').innerHTML;
+    }
+
+    // Expose functions to window
+    window.runBenchmark = runBenchmark;
+    window.runSequential = runSequential;
+    window.runParallel = runParallel;
+  </script>
+</body>
